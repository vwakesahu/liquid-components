{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "liquid-ui",
  "homepage": "https://liquidcomponents.xyz",
  "items": [
    {
      "name": "liquid-switch",
      "type": "registry:ui",
      "author": "Vivek Sahu <viveksahu1762@gmail.com>",
      "title": "Liquid Switch",
      "description": "A Radix-compatible switch with a responsive Liquid Glass tracker.",
      "dependencies": [
        "@radix-ui/react-switch",
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        {
          "path": "src/components/glass-switch.tsx",
          "type": "registry:ui",
          "target": "components/ui/liquid-switch.tsx"
        },
        {
          "path": "src/hooks/use-liquid-motion.ts",
          "type": "registry:hook",
          "target": "hooks/use-liquid-motion.ts"
        },
        {
          "path": "src/hooks/use-liquid-displacement.tsx",
          "type": "registry:hook",
          "target": "hooks/use-liquid-displacement.tsx"
        },
        {
          "path": "src/lib/utils.ts",
          "type": "registry:lib",
          "target": "lib/utils.ts"
        },
        {
          "path": "src/styles/liquid.css",
          "type": "registry:style",
          "target": "styles/liquid.css"
        }
      ]
    },
    {
      "name": "liquid-slider",
