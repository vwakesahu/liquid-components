{
  "name": "liquid-ui-monorepo",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "author": "Vivek Sahu",
  "homepage": "https://liquidcomponents.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/vwakesahu/liquid-components.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run playground:dev",
    "playground:dev": "bun --cwd apps/playground dev",
    "playground:build": "bun --cwd apps/playground build",
    "docs:dev": "bun --cwd apps/docs dev",
    "docs:build": "bun --cwd apps/docs build",
    "package:check": "bun --cwd packages/liquid-ui check",
    "check": "bun run package:check && bun --cwd apps/playground check",
    "build": "bun run playground:build",
    "registry:validate": "shadcn registry validate registry.json",
    "registry:build": "shadcn build registry.json && shadcn build registry.json --output apps/docs/public/r",
    "ci": "bun run check && bun run registry:validate && bun run build && bun run docs:build"
  },
  "devDependencies": {
    "shadcn": "^4.13.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.10"
}
